# SYSGRID Backend Configuration

# API Configuration
PROJECT_NAME="SYSGRID Production API"
API_V1_STR="/api/v1"

# Environment: development, production, test
ENVIRONMENT=development

# CORS Configuration
# Comma-separated list of allowed origins
# BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
BACKEND_CORS_ORIGINS=["*"]

# Database Configuration
# For SQLite: sqlite+aiosqlite:///./system_grid.db
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./system_grid.db
