# PathOS Backend Configuration
DATABASE_URL=sqlite+aiosqlite:///./pathos.db
DEBUG=true
PORT=8001
HOST=127.0.0.1
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000
ENVIRONMENT=development
# Pragma settings for high concurrency SQLite (WAL mode)
SQLITE_JOURNAL_MODE=WAL
SQLITE_BUSY_TIMEOUT=5000
SQLITE_SYNCHRONOUS=NORMAL
